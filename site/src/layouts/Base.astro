---
import "../styles/global.css";
import Analytics from "../components/Analytics.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "StackLight — All your deploys. One menu bar.",
  description = "StackLight watches every deploy and pull request you ship across Vercel, GitHub, Cloudflare, Netlify, Railway, Zeabur, Fly.io, Xcode Cloud, and TestFlight. Lives in your Mac menu bar. Free and open source.",
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://stacklight.pages.dev");
const ogImage = new URL("/og.png", siteUrl).toString();
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="StackLight" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="StackLight — a macOS menu bar app showing live deploy status across supported services." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="StackLight — a macOS menu bar app showing live deploy status across supported services." />

    <!-- liquid-glass web component (winaviation/liquid-web). Defines the
         <liquid-glass> custom element used by MenuBarMock.astro. -->
    <script type="module" src="/scripts/lg-component.js" is:inline></script>

    <Analytics />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-full focus:bg-ink focus:text-white focus:px-4 focus:py-2 focus:text-sm focus:font-medium"
    >
      Skip to content
    </a>
    <slot />
  </body>
</html>
