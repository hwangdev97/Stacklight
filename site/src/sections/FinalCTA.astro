---
import Button from "../components/Button.astro";
---

<section class="border-t border-hairline">
  <div class="mx-auto max-w-container px-6 py-28 md:py-36">
    <div class="flex flex-col items-center text-center gap-8">
      <h2 class="text-display-lg font-semibold text-ink max-w-2xl">
        Get every deploy in one click.
      </h2>
      <p class="text-lg text-muted max-w-xl">
        Free, open source, and small enough that you'll forget it's running.
      </p>
      <div class="flex flex-col sm:flex-row items-center gap-3 sm:gap-4">
        <Button href="https://github.com/hwangdev97/Stacklight/releases">
          Download for macOS
        </Button>
        <Button href="https://github.com/hwangdev97/Stacklight" variant="secondary">
          Star on GitHub
        </Button>
      </div>
    </div>
  </div>
</section>
