---
import Button from "../components/Button.astro";
---

<section class="relative overflow-hidden bg-hero-glow">
  <div class="mx-auto max-w-container px-6 pt-28 pb-24 md:pt-36 md:pb-32">
    <div class="flex flex-col items-center text-center gap-8">
      <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-ink text-white text-2xl">
        <span aria-hidden="true">▲</span>
      </div>
      <h1 class="text-display-xl font-semibold tracking-tight text-ink max-w-3xl">
        All your deploys.<br />One menu bar.
      </h1>
      <p class="max-w-2xl text-lg md:text-xl leading-relaxed text-muted">
        StackLight watches every deploy and pull request you ship —
        across Vercel, GitHub, Cloudflare, Netlify, Railway, Fly.io,
        Xcode Cloud, and TestFlight — and lives quietly in your Mac
        menu bar.
      </p>
      <div class="flex flex-col sm:flex-row items-center gap-3 sm:gap-4">
        <Button href="https://github.com/hwangdev97/Stacklight/releases">
          Download for macOS
        </Button>
        <Button href="https://github.com/hwangdev97/Stacklight" variant="secondary">
          View on GitHub
        </Button>
      </div>
      <p class="text-sm text-muted">
        Free and open source · macOS 13+ · No account required.
      </p>
    </div>
  </div>
</section>
