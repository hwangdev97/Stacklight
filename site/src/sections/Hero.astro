---
import MenuBarMock from "../components/MenuBarMock.astro";

// Default to the user-pinned release tag. Client-side script below upgrades
// the link to the actual latest release asset URL on page load.
const FALLBACK_RELEASE = "https://github.com/hwangdev97/Stacklight/releases/tag/v0.1.0";
---

<script>
  // Hero wallpaper rendering.
  //
  // Native paper.design mesh-gradient shader on every device. The shader is
  // static (speed=0): one paint, no rAF loop after.
  //
  // The iOS Safari perf trap is *not* the shader itself — it's
  // `backdrop-filter: blur()` stacked over a WebGL surface that can't be
  // promoted to a fast-path texture. Two things keep it cheap:
  //   1. preserveDrawingBuffer:false + antialias:false → Safari can promote
  //      the canvas to a composited texture, the same fast path it uses for
  //      <img>. (Old code had both true for an html2canvas snapshot path that
  //      no longer exists.)
  //   2. On iOS, MenuBarMock drops its backdrop-filter (see .no-glass below);
  //      without the backdrop-blur over the canvas, iOS compositing is fine.
  import {
    ShaderMount,
    staticMeshGradientFragmentShader,
    getShaderColorFromString,
    ShaderFitOptions,
  } from "@paper-design/shaders";
  import { HERO_SHADER_COLORS, HERO_SHADER_PARAMS } from "../shader-uniforms";

  // iPadOS 13+ reports as Mac, so also flag touch + Apple vendor.
  function isIOSLike(): boolean {
    const ua = navigator.userAgent;
    if (/iPad|iPhone|iPod/.test(ua)) return true;
    return (
      navigator.maxTouchPoints > 1 &&
      /Macintosh/.test(ua) &&
      /Apple/.test(navigator.vendor)
    );
  }

  function mountHeroShader() {
    // Tag the document on iOS so MenuBarMock can drop its backdrop-filters.
    // This is what actually fixes the iOS perf — not skipping the shader.
    if (isIOSLike()) {
      document.documentElement.classList.add("no-glass");
    }

    const host = document.querySelector(".hero-wallpaper-bg") as HTMLElement | null;
    if (!host || host.dataset.shaderMounted === "1") return;
    host.dataset.shaderMounted = "1";

    const colors = HERO_SHADER_COLORS.map(getShaderColorFromString);

    new ShaderMount(
      host,
      staticMeshGradientFragmentShader,
      {
        ...HERO_SHADER_PARAMS,
        u_colors: colors,
        u_fit: ShaderFitOptions.cover,
      },
      // Drop both flags so Safari can hardware-composite the canvas.
      { preserveDrawingBuffer: false, antialias: false },
      0, // speed=0 → static, no rAF loop after first paint
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", mountHeroShader);
  } else {
    mountHeroShader();
  }

  // Resolve the download link to the actual latest release asset on page load.
  // Caches the resolved URL in sessionStorage so we only hit the GitHub API
  // once per tab and don't burn the unauthenticated 60 req/hr rate limit.
  function resolveLatestRelease() {
    const a = document.getElementById("hero-download") as HTMLAnchorElement | null;
    if (!a) return;
    const cached = sessionStorage.getItem("stacklight-latest-release");
    if (cached) {
      const { href, tag } = JSON.parse(cached);
      a.href = href;
      const v = a.querySelector("[data-version]");
      if (v && tag) v.textContent = tag;
      return;
    }
    fetch("https://api.github.com/repos/hwangdev97/Stacklight/releases/latest", {
      headers: { Accept: "application/vnd.github+json" },
    })
      .then((r) => (r.ok ? r.json() : null))
      .then((release) => {
        if (!release) return;
        const dmg = (release.assets || []).find((x: any) =>
          /\.dmg$/i.test(x.name || "")
        );
        const href = dmg?.browser_download_url || release.html_url || a.href;
        const tag = release.tag_name || "";
        a.href = href;
        const v = a.querySelector("[data-version]");
        if (v && tag) v.textContent = tag;
        sessionStorage.setItem(
          "stacklight-latest-release",
          JSON.stringify({ href, tag })
        );
      })
      .catch(() => {
        /* keep the fallback href */
      });
  }
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", resolveLatestRelease);
  } else {
    resolveLatestRelease();
  }
</script>

<section class="relative overflow-hidden bg-white min-h-screen md:h-screen flex items-center">
  <!-- Original soft hero glow + grain backdrop -->
  <div class="absolute inset-0 bg-hero-glow pointer-events-none"></div>
  <div class="absolute inset-0 grid-noise opacity-[0.4] pointer-events-none [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,black,transparent_70%)]"></div>

  <div class="relative mx-auto max-w-container px-4 sm:px-6 py-8 md:py-14 w-full">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
      <div class="flex flex-col items-center md:items-start text-center md:text-left gap-5 sm:gap-7">
        <h1 class="text-[2rem] sm:text-[clamp(2.5rem,4.5vw,4rem)] leading-[1.05] tracking-tight font-semibold text-ink">
          All your deploys.<br />One menu bar.
        </h1>
        <p class="text-base sm:text-lg leading-relaxed text-muted max-w-xl">
          StackLight watches every deploy and pull request you ship —
          across Vercel, GitHub, Cloudflare, Netlify, Railway, Fly.io,
          Xcode Cloud, and TestFlight — and lives quietly in your Mac
          menu bar.
        </p>
        <div class="flex flex-col sm:flex-row items-center md:items-start gap-3 sm:gap-4 pt-2">
          <a
            id="hero-download"
            href={FALLBACK_RELEASE}
            data-fallback={FALLBACK_RELEASE}
            class="inline-flex items-center justify-center gap-2 rounded-full bg-ink text-white text-base font-medium px-6 py-3"
          >
            Download for macOS
            <span class="text-white/60 text-sm font-normal" data-version></span>
          </a>
        </div>
        <p class="text-sm text-muted">
          Free and open source · macOS 13+ · No account required.
        </p>
      </div>

      <!-- Right column wraps the mock with a wallpaper backdrop that bleeds
           far to the right (clipped by section overflow-hidden) and into the
           copy column to the left, but stays only slightly taller than the
           mock vertically. The left→right fade mask matches the earlier
           version. -->
      <div class="md:justify-self-end w-full max-w-[340px] sm:max-w-[400px] mx-auto md:mx-0 relative">
        <div
          class="hero-wallpaper-bg absolute -inset-y-6 -z-0 pointer-events-none overflow-hidden"
          aria-hidden="true"
          style="left: -100%;
                 right: -100vw;
                 -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.35) 28%, black 55%);
                 mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.35) 28%, black 55%);"
        ></div>
        <div class="relative z-10">
          <MenuBarMock />
        </div>
      </div>
    </div>
  </div>
</section>
