---
interface Props {
  name: string;
  caption: string;
  src?: string;
  glyph?: string;
}

const { name, caption, src, glyph } = Astro.props;
---

<div class="group flex flex-col items-center gap-3 rounded-2xl border border-hairline bg-white p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-card">
  <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-surface group-hover:bg-white group-hover:ring-1 group-hover:ring-hairline transition-colors">
    {
      src ? (
        <img src={src} alt="" class="h-7 w-7 object-contain" loading="lazy" />
      ) : (
        <span class="text-base font-semibold text-ink">{glyph ?? name.charAt(0)}</span>
      )
    }
  </div>
  <div class="text-center">
    <p class="text-sm font-semibold text-ink">{name}</p>
    <p class="text-xs text-muted mt-0.5">{caption}</p>
  </div>
</div>
