---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  icon?: Parameters<typeof Icon>[0]["name"];
}

const { title, icon } = Astro.props;
---

<div class="flex flex-col gap-4 rounded-2xl border border-hairline bg-white p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-card">
  {
    icon && (
      <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-surface text-ink">
        <Icon name={icon} class="h-5 w-5" />
      </span>
    )
  }
  <h3 class="text-lg font-semibold text-ink">{title}</h3>
  <p class="text-base leading-relaxed text-muted">
    <slot />
  </p>
</div>
