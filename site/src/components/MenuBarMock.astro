---
type State = "ok" | "warn" | "fail";

interface Item {
  state: State;
  title: string;
  meta?: string;
  meta2?: string;
  time: string;
}

interface Section {
  name: string;
  logo: string;
  /** Solid brand color used as the radial-gradient base for the icon badge. */
  brand: string;
  /** Render the logo as-is (no brand-tint, no white silhouette filter). Use
   *  for icons that already carry their own design — multi-color marks or
   *  full iOS-style app icons. */
  flat?: boolean;
  items?: Item[];
  empty?: string;
}

const sections: Section[] = [
  {
    name: "Vercel",
    logo: "/logos/vercel.svg",
    brand: "#1a1a1a",
    items: [
      { state: "ok", title: "slabox-app-landing", meta: "main", time: "11h ago" },
      { state: "ok", title: "slabox-app-la…", meta: "claude/ios-slider-hap…", time: "11h ago" },
      { state: "ok", title: "viber-today", meta: "main", time: "1d ago" },
      { state: "ok", title: "viber-today", meta: "claude/update-viber-mobile…", time: "1d ago" },
      { state: "ok", title: "viber-today", meta: "main", time: "1d ago" },
    ],
  },
  {
    name: "Cloudflare Pages",
    logo: "/logos/cloudflarepages.svg",
    brand: "#F38020",
    empty: "No recent deployments",
  },
  {
    name: "GitHub Actions",
    logo: "/logos/github.svg",
    brand: "#24292f",
    items: [
      { state: "warn", title: "Addressing…", meta: "Stacklight", meta2: "claude/optimi…", time: "3m ago" },
      { state: "ok", title: "CI", meta: "Stacklight", meta2: "main", time: "39m ago" },
      { state: "ok", title: "Release", meta: "recappi-mini", meta2: "v1.0.66", time: "1h ago" },
      { state: "ok", title: "Release", meta: "recappi-mini", meta2: "v1.0.65", time: "3h ago" },
      { state: "ok", title: "CI", meta: "Stacklight", meta2: "claude/investigate-ios-cac…", time: "8h ago" },
    ],
  },
  {
    name: "Xcode Cloud",
    logo: "/logos/xcodecloud.svg",
    brand: "#147EFB",
    items: [
      { state: "fail", title: "StackLight", time: "39m ago" },
      { state: "ok", title: "StackLight", time: "10h ago" },
      { state: "ok", title: "SlabShelf", time: "11h ago" },
      { state: "ok", title: "StackLight", time: "21h ago" },
      { state: "fail", title: "viber-today", time: "1d ago" },
    ],
  },
  {
    name: "TestFlight",
    logo: "/logos/testflight.jpg",
    brand: "#0D96F6",
    flat: true,
    items: [
      { state: "ok", title: "StackLight v57", time: "19m ago" },
      { state: "ok", title: "StackLight v56", time: "9h ago" },
      { state: "ok", title: "StackLight v56", time: "9h ago" },
      { state: "ok", title: "StackLight v55", time: "21h ago" },
      { state: "ok", title: "StackLight v55", time: "21h ago" },
    ],
  },
];

const footerItems: { label: string; shortcut?: string }[] = [
  { label: "Refresh Now", shortcut: "⌘R" },
  { label: "Settings…", shortcut: "⌘," },
  { label: "Send Feedback…" },
  { label: "Updates via Mac App Store" },
  { label: "Quit StackLight", shortcut: "⌘Q" },
];

const dotClass: Record<State, string> = {
  ok: "bg-[#30d158]",
  warn: "bg-[#ffd60a]",
  fail: "bg-[#ff453a]",
};
---

<div class="hero-glass-stage relative w-full max-w-[360px] mx-auto select-none font-sans" role="img" aria-label="StackLight macOS menu showing recent deploys across Vercel, Cloudflare Pages, GitHub Actions, Xcode Cloud, and TestFlight.">
  <!-- Faux menu bar strip with icons (StackLight highlighted). Stays on plain
       CSS backdrop-filter — only the dropdown below gets the liquid-glass
       refraction, matching how macOS actually paints these elements. -->
  <div class="menu-bar-strip relative z-10 rounded-lg border border-white/10 px-2 h-6 flex items-center justify-end gap-2.5 text-[10px] text-white/55">
    {Array.from({ length: 6 }).map(() => (
      <span class="h-2.5 w-2.5 rounded-sm bg-white/20"></span>
    ))}
    <span class="relative h-4 w-4 rounded bg-white/10 ring-1 ring-white/30 flex items-center justify-center">
      <img src="/menubar-icon.png" alt="StackLight" class="h-3.5 w-3.5 invert opacity-95" />
    </span>
    {Array.from({ length: 4 }).map(() => (
      <span class="h-2.5 w-2.5 rounded-sm bg-white/20"></span>
    ))}
    <span class="opacity-70">100%</span>
    <span class="opacity-70">Tue 9:41</span>
  </div>

  <!-- Dropdown wrapped in <liquid-glass>. The component refracts whatever's
       behind it (the hero shader gradient) via SVG displacement maps + native
       backdrop-filter. JS below sizes the height to match the real content. -->
  <div class="mt-1.5 ml-auto w-full">
    <liquid-glass
      class="dropdown-glass"
      width="360"
      height="640"
      radius="10"
      type="squircle"
      surface-type="convex_squircle"
      bezel-width="14"
      glass-thickness="60"
      refraction-scale="1.2"
      specular-opacity="0.7"
      blur="6"
      fallback-blur="22"
      tint="rgba(20, 20, 24, 0.55)"
      flex-center="false"
    >
      <!-- Slotted content. The component centers slotted content by default
           via flexbox; flex-center="false" turns that off so we can use our
           own block layout. -->
      <div class="dropdown-content w-full text-[12px] leading-tight text-white/95">
        {sections.map((section) => (
          <div class="px-1 pt-1.5">
            <!-- Section header -->
            <div class="flex items-center gap-2 px-2 py-1 text-white">
              {section.flat ? (
                <span
                  class="icon-flat shrink-0"
                  style={`background-image: url(${section.logo});`}
                  aria-hidden="true"
                ></span>
              ) : (
                <span class="icon-badge shrink-0" style={`--brand: ${section.brand};`}>
                  <img src={section.logo} alt="" loading="lazy" />
                </span>
              )}
              <span class="font-semibold text-[13px] flex-1 truncate">{section.name}</span>
              <svg class="h-3 w-3 text-white/35 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17 L17 7" />
                <path d="M9 7h8v8" />
              </svg>
            </div>

            {section.empty ? (
              <div class="px-2 pb-1.5 pt-0.5 text-white/45 text-[12px]">{section.empty}</div>
            ) : (
              <div>
                {section.items!.map((item) => (
                  <div class="flex items-center gap-2 px-2 py-[5px] rounded-md hover:bg-white/[0.08]">
                    <span class={`h-[7px] w-[7px] rounded-full shrink-0 ${dotClass[item.state]}`}></span>
                    <span class="font-semibold text-white truncate shrink-0 max-w-[40%]">{item.title}</span>
                    {item.meta && (
                      <span class="text-white/55 truncate shrink min-w-0">{item.meta}</span>
                    )}
                    {item.meta2 && (
                      <span class="text-white/40 truncate shrink min-w-0 hidden sm:inline">{item.meta2}</span>
                    )}
                    <span class="ml-auto text-white/40 text-[11px] whitespace-nowrap shrink-0 pl-1">{item.time}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        ))}

        <!-- Status line -->
        <div class="px-3 pt-2 pb-1 text-[11px] text-white/40">
          Updated in 0s · 5/5 ok
        </div>

        <!-- Divider -->
        <div class="mx-2 h-px bg-white/[0.08]"></div>

        <!-- Footer menu items -->
        <div class="px-1 py-1">
          {footerItems.map((item) => (
            <div class="flex items-center px-2 py-[5px] rounded-md hover:bg-white/[0.08]">
              <span class="flex-1 text-white/95">{item.label}</span>
              {item.shortcut && <span class="text-white/45 text-[11px] tracking-wide font-mono">{item.shortcut}</span>}
            </div>
          ))}
        </div>
      </div>
    </liquid-glass>
  </div>
</div>

<style>
  .menu-bar-strip {
    background-color: rgba(28, 28, 30, 0.55);
    -webkit-backdrop-filter: blur(20px) saturate(170%);
    backdrop-filter: blur(20px) saturate(170%);
  }

  /* The liquid-glass element renders as inline-block by default; let it fill
     the wrapper width-wise. Width attribute still drives the SVG filter math. */
  liquid-glass.dropdown-glass {
    display: block;
  }

  /* The slotted content needs to live in a normal block flow, not centered. */
  liquid-glass.dropdown-glass .dropdown-content {
    display: block;
    width: 100%;
  }

  /* Fallback in older Firefox without backdrop-filter: a solid-ish dark tint
     so the text still has contrast. */
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .menu-bar-strip { background-color: rgba(20, 20, 22, 0.94); }
  }

  /* Section header icon badge: a small glossy sphere in the brand color
     (set per section via --brand inline style), with a top highlight arc
     and a forced-white logo silhouette in the middle. Mimics the macOS
     "tinted app icon" look. */
  .icon-badge {
    position: relative;
    width: 20px;
    height: 20px;
    border-radius: 9999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background:
      radial-gradient(120% 90% at 50% 110%,
        color-mix(in srgb, var(--brand) 70%, #000) 0%,
        var(--brand) 60%);
    box-shadow:
      inset 0 0.5px 0 rgba(255, 255, 255, 0.45),
      inset 0 -1px 1.5px rgba(0, 0, 0, 0.35),
      0 0.5px 1px rgba(0, 0, 0, 0.35);
  }
  /* Glossy top reflection arc */
  .icon-badge::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background:
      radial-gradient(120% 60% at 50% -10%,
        rgba(255, 255, 255, 0.55) 0%,
        rgba(255, 255, 255, 0.18) 35%,
        transparent 60%);
  }
  .icon-badge img {
    position: relative;
    z-index: 1;
    width: 60%;
    height: 60%;
    object-fit: contain;
    /* Force any logo to a clean white silhouette so it reads on every brand. */
    filter: brightness(0) invert(1);
  }

  /* "Flat" variant for icons that already carry their own design (multi-color
     marks, full iOS-style app icons). Rendered as a div with background-image
     so we can zoom past the source's intrinsic padding (e.g. the iOS preview
     padding around an app icon). background-size > 100% pulls the visible
     content out to the edge of the circle, eliminating any letterbox between
     icon and circle border. */
  .icon-flat {
    display: inline-block;
    width: 20px;
    height: 20px;
    border-radius: 9999px;
    background-size: 150% 150%;
    background-position: center;
    background-repeat: no-repeat;
    filter: drop-shadow(0 0.5px 1px rgba(0, 0, 0, 0.35));
  }
</style>

<script is:inline>
  /*
   * One-shot height-fit for <liquid-glass>. The component needs an explicit
   * `height` attribute (it generates an SVG displacement map at that exact
   * size), but our slotted menu content has a content-derived height. We
   * measure the slotted content once, after fonts + images have settled,
   * and write the result to the attribute.
   *
   * We deliberately do NOT listen to window resize — the lib's own internal
   * resize observer fires synthetic resize events that would otherwise
   * trigger a feedback loop and balloon the height.
   */
  (function () {
    function fitOnce(el) {
      if (el.dataset.fitDone === "1") return;
      const slot = el.querySelector(".dropdown-content");
      if (!slot) return;
      const measured = Math.ceil(slot.scrollHeight);
      if (measured > 0) {
        el.setAttribute("height", String(measured));
        el.dataset.fitDone = "1";
      }
    }
    function run() {
      const els = document.querySelectorAll("liquid-glass.dropdown-glass");
      // Wait for any <img> children to load so scrollHeight is final.
      const imgs = Array.from(document.querySelectorAll(".dropdown-content img"));
      const allLoaded = Promise.all(
        imgs.map((img) =>
          img.complete
            ? Promise.resolve()
            : new Promise((res) => {
                img.addEventListener("load", res, { once: true });
                img.addEventListener("error", res, { once: true });
              })
        )
      );
      allLoaded.then(() => {
        requestAnimationFrame(() => requestAnimationFrame(() => {
          els.forEach(fitOnce);
        }));
      });
    }
    if (customElements.get("liquid-glass")) {
      run();
    } else {
      customElements.whenDefined("liquid-glass").then(run);
    }
  })();
</script>
